;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Offline Classics"
run/main_scene="uid://bblkhe0fd43xi"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameColors="*uid://pi2216hvhymn"
SaveManager="*uid://cxnf3gyym8tgg"

[display]

